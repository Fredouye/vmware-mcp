# VMWare MCP — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The `export` prefix lets you also `source .env` for direct govc CLI usage.
# Bun auto-loads .env files at startup.

# Required
export GOVC_URL=https://vcenter.example.com/sdk
export GOVC_USERNAME=admin@vsphere.local
export GOVC_PASSWORD=
export GOVC_INSECURE=1

# Optional
# export MCP_TRANSPORT=stdio     # stdio (default) | http
# export MCP_AUTH_TOKEN=         # required in http mode — generate with: openssl rand -hex 32
# export HTTP_HOST=127.0.0.1     # http mode bind address
# export HTTP_PORT=3211
# export MCP_ALLOWED_HOSTS=      # comma-separated Host allowlist (DNS-rebinding protection)
# export GOVC_BIN=govc
# export GOVC_TIMEOUT_MS=120000
